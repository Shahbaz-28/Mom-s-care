# Copy to .env.local and fill in from Supabase → Project Settings → API

# Project URL only (NO /rest/v1 suffix)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only — used by /api routes (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional — weather location for Open-Meteo (defaults: Delhi, India)
WEATHER_LAT=28.6139
WEATHER_LON=77.2090
# WEATHER_LOCATION_LABEL=Delhi, India

# Optional — Telegram alerts when symptom severity >= threshold (default 8)
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_CHAT_ID=your_numeric_chat_id
# TELEGRAM_SEVERITY_THRESHOLD=8
# TELEGRAM_MISSED_MEDS_DAYS=2
